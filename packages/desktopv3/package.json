{
  "name": "greenlight-desktopv3",
  "version": "0.1.0",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "start": "yarn build && electron-forge start",
    "dev": "yarn build && electron-forge start",
    "build": "rm -rf dist/ && webpack -c ./webpack.config.ts && cp -r web dist/",
    "build:web": "cd ../../ && rm -rf packages/desktopv3/web && yarn web build && cp -r packages/web/dist packages/desktopv3/web",
    "test": "echo \"Error: no test specified\" && exit 1",
    "package": "yarn build && electron-forge package",
    "make": "yarn build && electron-forge make"
  },
  "dependencies": {
    "bufferutil": "^4.0.9",
    "electron-squirrel-startup": "^1.0.1",
    "electron-trpc": "^0.7.1",
    "utf-8-validate": "^6.0.5"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.8.0",
    "@electron-forge/maker-deb": "^7.8.0",
    "@electron-forge/maker-dmg": "^7.8.0",
    "@electron-forge/maker-rpm": "^7.8.0",
    "@electron-forge/maker-squirrel": "^7.8.0",
    "@electron-forge/maker-zip": "^7.8.0",
    "@electron-forge/plugin-auto-unpack-natives": "^7.8.0",
    "@electron-forge/plugin-fuses": "^7.8.0",
    "@electron/fuses": "^1.8.0",
    "@greenlight/server": "^0.1.0",
    "@trpc/server": "^11.1.0",
    "electron": "^35.1.5",
    "electron-trpc": "^0.7.1",
    "mime": "^4.0.7",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "webpack": "^5.99.6",
    "webpack-cli": "^6.0.1"
  },
  "files": [
    "web/**/*",
    "!**/node_modules/*",
    "!**/dist/*",
    "!**/src/*",
    "web/index.html"
  ]
}
