{
  "name": "@greenlight/player",
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "exports": {
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build:client": "vite build",
    "build:server": "tsup",
    "build": "yarn clean && yarn build:client && yarn build:server",
    "clean": "rm -rf dist/",
    "test": "mocha",
    "dev": "concurrently \"yarn dev:server\" \"yarn dev:client\"",
    "dev:client": "vite build --watch",
    "dev:server": "tsup --watch"
  },
  "peerDependencies": {
    "react": "^18.0.0"
  },
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.0.2",
    "@types/react": "^19.2.14",
    "@types/sinon": "^21.0.0",
    "@vitejs/plugin-react": "^5.1.2",
    "chai": "^6.2.1",
    "concurrently": "^9.1.2",
    "mocha": "^11.7.5",
    "react": "^19.2.6",
    "sinon": "^22.0.0",
    "tsup": "^8.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.0",
    "vite-plugin-dts": "^4.5.4"
  },
  "dependencies": {
    "uuid": "^13.0.0"
  }
}
