{
  "name": "@greenlight/platform-playground",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "predev": "yarn workspace @greenlight/player build && yarn workspace @greenlight/platform build && yarn workspace @greenlight/player build",
    "dev": "concurrently \"yarn server\" \"yarn vite\"",
    "server": "tsx watch src/server/index.ts",
    "vite": "vite",
    "build": "yarn workspace @greenlight/platform build && yarn workspace @greenlight/player build && tsc && vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist/"
  },
  "dependencies": {
    "@greenlight/platform": "*",
    "@tanstack/react-query": "^5.90.10",
    "@trpc/client": "^11.1.0",
    "@trpc/server": "^11.1.0",
    "@trpc/tanstack-react-query": "^11.7.2",
    "cors": "^2.8.5",
    "express": "^4.21.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.14.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.3",
    "typescript": "^5.9.3",
    "vite": "^5.4.11"
  }
}
