{
	"private": true,
	"name": "blacklight-desktop-tauri",
	"description": "Blacklight desktop shell (Tauri, Windows/macOS)",
	"version": "2026.7.6",
	"author": "Igor Samarin <mako.mmw@gmail.com>",
	"license": "PolyForm-Noncommercial-1.0.0",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/isamarin/blacklight.git"
	},
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"dev:tauri": "bash scripts/tauri-dev-server.sh",
		"tauri:stop": "bash scripts/stop-tauri-dev.sh",
		"build": "vite build && node scripts/fix-tauri-spa-paths.mjs",
		"preview": "vite preview --host 127.0.0.1 --port 4173 --strictPort",
		"tauri": "tauri",
		"tauri:dev": "tauri dev",
		"tauri:dev:clean": "bash scripts/stop-tauri-dev.sh && tauri dev",
		"tauri:build": "tauri build",
		"prepare": "svelte-kit sync || echo ''",
		"test": "vitest run",
		"smoke:api": "tsx scripts/smoke-auth-stream.ts",
		"smoke:e2e": "bash scripts/smoke-test-e2e.sh",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"api": "tsx api/server.ts",
		"api:watch": "tsx watch api/server.ts",
		"build:api": "node api/build.mjs"
	},
	"dependencies": {
		"@blacklight/platform": "workspace:*",
		"@blacklight/player": "workspace:*",
		"@tauri-apps/api": "^2.10.0",
		"@tauri-apps/plugin-opener": "^2.5.0",
		"@trpc/client": "^11.17.0",
		"@trpc/server": "^11.17.0",
		"i18next": "^26.3.4",
		"qrcode": "^1.5.4",
		"react": "^19.2.7",
		"react-dom": "^19.2.7"
	},
	"devDependencies": {
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/postcss": "^4.2.2",
		"@tailwindcss/vite": "^4.2.2",
		"@tauri-apps/cli": "^2.10.0",
		"@types/node": "^25.9.3",
		"@types/qrcode": "^1.5.6",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@yao-pkg/pkg": "^6.20.0",
		"concurrently": "^9.2.1",
		"esbuild": "^0.28.1",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"tailwindcss": "^4.2.2",
		"tsx": "^4.21.0",
		"typescript": "^5.8.2",
		"vite": "^8.0.16",
		"vitest": "^4.1.9"
	}
}