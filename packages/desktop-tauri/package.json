    "express": "^5.2.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.0",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.3",
    "@yao-pkg/pkg": "^6.20.0",
    "concurrently": "^9.2.1",
    "esbuild": "^0.28.1",
    "tsx": "^4.21.0",
    "typescript": "^5.8.2"
  }
}