{
  "private": true,
  "name": "blacklight-desktop-tauri",
  "description": "Blacklight desktop shell (Tauri, Windows/macOS)",
  "version": "2026.7.1-alpha.1",
  "author": "Igor Samarin <mako.mmw@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/isamarin/blacklight.git"
  },
  "type": "module",
  "scripts": {
    "sidecar": "tsx sidecar/server.ts",
    "sidecar:watch": "tsx watch sidecar/server.ts",
