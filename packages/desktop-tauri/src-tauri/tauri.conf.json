{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Greenlight",
  "version": "2026.7.1-alpha.1",
  "identifier": "com.unknownskl.greenlight",
  "build": {
    "devUrl": "http://127.0.0.1:9003/home/",
    "beforeBuildCommand": "pnpm --filter greenlight-desktop-tauri run build:renderer",
    "frontendDist": "../../desktop-v3/app"
  },
  "app": {
    "windows": [
      {
        "title": "Greenlight",
        "width": 1000,
        "height": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self' http://127.0.0.1:9003 http://localhost:9003; connect-src 'self' http://127.0.0.1:9003 http://localhost:9003 https: wss: ws:; img-src 'self' http://127.0.0.1:9003 http://localhost:9003 https: data: blob:; media-src 'self' https: blob:; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}