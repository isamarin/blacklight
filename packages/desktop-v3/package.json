    "@types/node": "^25.9.1",
    "@types/react": "^19.2.14",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "next": "^16.2.1",
    "nextron": "^10.0.0",
    "postcss": "^8.5.8",
