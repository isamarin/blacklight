{
  "private": true,
  "name": "greenlight",
  "description": "Greenlight is a streaming application for Xbox and xCloud",
  "version": "2.3.1",
  "author": "UnknownSKL <info+github@jimkroon.nl>",
  "main": "app/background.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/unknownskl/greenlight.git"
  },
  "scripts": {
    "dev": "DEBUG=greenlight:* nextron", 
    "build": "nextron build",
    "lint": "eslint . --ext .ts && eslint renderer/ --ext .tsx",
    "lint:fix": "eslint . --ext .ts --fix && eslint renderer/ --ext .tsx --fix",
    "test": "echo \"Error: no test specified\" && exit 0",
    "test:disabled": "CI=true nextron build --no-pack && CI=true xvfb-maybe -- playwright test -c playwright.config.ts",
    "test-serve": "npx http-server app/ -p 3000",
    "postinstall": "electron-builder install-app-deps",
    "publish": "electron-builder -p onTag",
    "flatpak-build": "nextron build --no-pack && electron-builder --dir"
  },
  "dependencies": {
    "axios": "^1.6.8",
    "compare-versions": "^6.1.0",
    "debug": "^4.3.4",
    "electron-serve": "^2.1.1",
    "electron-store": "^10.0.1",
    "express": "^4.21.2",
    "express-http-proxy": "^2.0.0",
    "express-ws": "^5.0.2",
    "github-url-to-object": "^4.0.6",
    "ip-address": "^10.0.1",
    "react-query": "^3.39.3",
    "uplot": "^1.6.30",
    "xal-node": "^1.0.2",
    "xbox-webapi": "^1.4.1",
    "xbox-xcloud-player": "^0.2.11",
    "xvfb-maybe": "^0.2.1"
  },
  "devDependencies": {
    "@babel/core": "^7.26.10",
    "@fortawesome/fontawesome-free": "^6.5.2",
    "@next/eslint-plugin-next": "^14.2.2",
    "@types/node": "^20.14.2",
    "@types/react": "^18.2.47",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^6.21.0",
    "babel-loader": "^9.1.3",
    "electron": "35",
    "electron-builder": "^26.0.12",
    "eslint": "^8.57.0",
    "next": "^15.1.5",
    "nextron": "^9.5.0",
    "node-loader": "^2.0.0",
    "react": "^18.1.0",
    "react-dom": "^18.1.0",
    "typescript": "^5.4.5"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
