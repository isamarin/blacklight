{
  "private": true,
  "name": "greenlight",
  "description": "Greenlight is a streaming application for Xbox and xCloud",
  "author": "Igor Samarin <mako.mmw@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/isamarin/greenlight.git"
  },
  "scripts": {
    "desktop": "pnpm --filter greenlight-desktop",
    "desktopv3": "pnpm --filter greenlight-desktop-v3",
    "docs": "pnpm --filter @greenlight/docs",
    "logger": "pnpm --filter @greenlight/logger",
    "platform": "pnpm --filter @greenlight/platform",
    "playground": "pnpm --filter @greenlight/platform-playground",
    "player": "pnpm --filter @greenlight/player",
    "pages": "pnpm --filter @greenlight/pages",
    "build:depsv3": "pnpm logger build && pnpm player build && pnpm platform build",
    "build:pages": "pnpm build:depsv3 && pnpm pages build",
    "deploy:pages": "pnpm pages deploy",
    "test:v3": "pnpm logger test && pnpm platform test"
  },
  "packageManager": "pnpm@10.4.1"
}