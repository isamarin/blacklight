{
  "private": true,
  "name": "blacklight",
  "description": "Blacklight — an Xbox streaming tool for xCloud and home streaming",
  "author": "Igor Samarin <mako.mmw@gmail.com>",
  "license": "PolyForm-Noncommercial-1.0.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/isamarin/blacklight.git"
  },
  "scripts": {
    "desktop": "pnpm --filter blacklight-desktop",
    "desktop-renderer": "pnpm --filter blacklight-desktop-v3",
    "desktop-tauri": "pnpm --filter blacklight-desktop-tauri",
    "docs": "pnpm --filter @blacklight/docs",
    "platform": "pnpm --dir ../platform",
    "playground": "pnpm --filter @blacklight/platform-playground",
    "player": "pnpm --dir ../player",
    "pages": "pnpm --filter @blacklight/pages",
    "site": "pnpm --dir ../site",
    "landing": "pnpm site",
    "build:landing": "pnpm site generate",
    "dev:landing": "pnpm site dev",
    "build:pages": "pnpm pages build",
    "build:web": "pnpm desktop-tauri build",
    "check:tauri": "pnpm desktop-tauri check",
    "deploy:pages": "pnpm pages deploy",
    "lint": "eslint --config eslint.config.mjs .",
    "test": "pnpm desktop-tauri test && pnpm pages test",
    "test:player": "pnpm player test",
    "test:platform": "pnpm platform test",
    "test:workspace": "pnpm test",
    "smoke:e2e": "pnpm desktop-tauri smoke:e2e",
    "dev:tauri": "pnpm desktop-tauri dev:tauri",
    "tauri:dev": "pnpm desktop-tauri tauri:dev"
  },
  "packageManager": "pnpm@10.4.1",
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "eslint": "^9.39.2",
    "globals": "^16.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}