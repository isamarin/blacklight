{
  "private": true,
  "name": "greenlight",
  "description": "Greenlight is a streaming application for Xbox and xCloud",
  "author": "UnknownSKL <info+github@jimkroon.nl>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/unknownskl/greenlight.git"
  },
  "scripts": {
    "desktop": "yarn workspace greenlight-desktop",
    "desktopv3": "yarn workspace greenlight-desktop-v3",
    "docs": "yarn workspace @greenlight/docs",
    "logger": "yarn workspace @greenlight/logger",
    "platform": "yarn workspace @greenlight/platform",
    "playground": "yarn workspace @greenlight/platform-playground",
    "player": "yarn workspace @greenlight/player",
    "pages": "yarn workspace @greenlight/pages",

    "build:depsv3": "yarn logger build && yarn player build && yarn platform build",
    "build:pages": "yarn build:depsv3 && yarn pages build",
    "deploy:pages": "yarn pages deploy",
    "test:v3": "yarn logger test && yarn platform test"
  },
  "workspaces": [
    "packages/logger",
    "packages/player",
    "packages/pages",
    "packages/platform",
    "packages/platform-playground",
    "packages/desktop",
    "packages/desktop-v3",
    "packages/docs"
  ],
  "packageManager": "pnpm@10.4.1"
}
